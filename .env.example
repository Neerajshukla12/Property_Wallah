# ========================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ========================================

# For Vite: Use VITE_ prefix
# Auto-detection: Leave empty to auto-detect based on hostname
# - localhost/127.0.0.1 → http://localhost:9002/ (Backend port)
# - Production → https://property-wala-backend.vercel.app/

# Uncomment to override auto-detection:
# VITE_API_BASE_URL=http://localhost:9002/
# For production:
# VITE_API_BASE_URL=https://property-wala-backend.vercel.app/

# ========================================
# ALTERNATIVE (React Create App format)
# ========================================
# REACT_APP_BASE_URL=http://localhost:9002/
